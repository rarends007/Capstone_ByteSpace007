<?xml version="1.0" encoding="UTF-8"?>
<Context path="/bytespace">
    <Resource name="jdbc/bytespaceDB" 
              auth="Container" 
              type="javax.sql.DataSource"
              driverClassName="com.mysql.cj.jdbc.Driver"
              url="jdbc:mysql://localhost:3306/bytespaceDB?autoReconnect=true&amp;useSSL=false&amp;allowPublicKeyRetrieval=true" 
              username="capstone_2026" 
              password="Password_Capstone_1475" 
              maxTotal="100" maxIdle="60" maxWaitMillis="10000"
              logAbandoned="true" removeAbandoned="true" removeAbandonedTimeout="90"/>

    <Realm className="org.apache.catalina.realm.DataSourceRealm" 
           debug="99"
           username="capstone_2026" 
           password="Password_Capstone_1475" 
           dataSourceName="jdbc/bytespaceDB" 
           localDataSource="true"
           userTable="user" 
           userNameCol="username" 
           userCredCol="credential" 
           userRoleTable="user_role" 
           roleNameCol="rolename">
                <CredentialHandler className="org.apache.catalina.realm.SecretKeyCredentialHandler" 
                                   algorithm="PBKDF2WithHmacSHA512" 
                                   iterations="4096" 
                                   keyLength="256" 
                                   saltLength="16"/>
    </Realm>
</Context>
<!--  must have mysql-connector-j-9.6.0.jar in the apache tomcat server lib folder -->
