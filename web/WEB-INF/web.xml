<?xml version="1.0" encoding="UTF-8"?>
<web-app version="4.0" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd">
    <!--All Controller mapping-->
    <servlet>
        <servlet-name>Admin</servlet-name>
        <servlet-class>controllers.AdminController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Admin</servlet-name>
        <url-pattern>/Admin</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>Teacher</servlet-name>
        <servlet-class>controllers.TeacherController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Teacher</servlet-name>
        <url-pattern>/Teacher</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>Public</servlet-name>
        <servlet-class>controllers.PublicController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Public</servlet-name>
        <url-pattern>/Public</url-pattern>
    </servlet-mapping>
    
    <!--Roles, Security Constraints, authenticaton config-->
    
    <!--roles-->
    <security-role>
        <description>Administrators</description>
        <role-name>ADMIN</role-name>
    </security-role>
    
    <security-role>
        <description>Members of the site.</description>
        <role-name>MEMBER</role-name>
    </security-role>
    
    <!--constraint containers-->
    <security-constraint>
        <web-resource-collection>
            <web-resource-name>Protected Area - A</web-resource-name>
            <url-pattern>/admin/*</url-pattern>
        </web-resource-collection>
        
        <auth-constraint>
            <role-name>ADMIN</role-name>
        </auth-constraint>

        <user-data-constraint>
            <transport-guarantee>CONFIDENTIAL</transport-guarantee>
        </user-data-constraint>
    </security-constraint>
    
       <security-constraint>
        <web-resource-collection>
            <web-resource-name>Protected Area - M</web-resource-name>
            <url-pattern>/member/*</url-pattern>
        </web-resource-collection>
        
        <auth-constraint>
            <role-name>MEMBER</role-name>
        </auth-constraint>

        <user-data-constraint>
            <transport-guarantee>CONFIDENTIAL</transport-guarantee>
        </user-data-constraint>
    </security-constraint>
    
    <!--Authentication Config-->
    <Login-config>
        <auth-method>BASIC</auth-method>
        <realm-name>Secure Area Login</realm-name>
    </Login-config>
    <!--Session config-->
    
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
